{
  "project": "Sentimind — Mental Health Sentiment Analysis",
  "dataset": "Kaggle Mental Health + TweetEval (reference)",
  "num_classes": 7,
  "labels": [
    "Normal",
    "Depression",
    "Anxiety",
    "Bipolar",
    "Personality Disorder",
    "Stress",
    "Suicidal"
  ],
  "dataset_size": {
    "raw": 71339,
    "after_cleaning": 71339,
    "train": 49937,
    "val": 10701,
    "test": 10701
  },
  "random_seed": 42,
  "models": {
    "bilstm": {
      "type": "RNN",
      "embedding_dim": 300,
      "hidden_dim": 256,
      "num_layers": 2,
      "epochs_trained": 6,
      "test_accuracy": 0.8244,
      "test_macro_f1": 0.8359
    },
    "bertweet": {
      "type": "Transformer",
      "pretrained": "vinai/bertweet-base",
      "epochs_trained": 50,
      "test_accuracy": 0.821,
      "test_macro_f1": 0.8268
    }
  },
  "semantic": {
    "embedding_model": "all-MiniLM-L6-v2",
    "embedding_dim": 384,
    "umap": {
      "n_neighbors": 30,
      "min_dist": 0.05
    },
    "hdbscan": {
      "min_cluster_size": 120,
      "min_samples": 10
    }
  }
}